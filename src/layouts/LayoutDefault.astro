---
import { themeConfig } from '~/.config'
import SiteFooter from '~/components/SiteFooter.astro'
import SiteNavigation from '~/components/SiteNavigation.astro'
import SiteTitle from '~/components/SiteTitle.astro'
import SiteSeo from '~/components/SiteSeo.astro'
import Analytics from '~/components/Analytics.astro'
import '~/styles/global.css'

const lang = themeConfig.appearance.locale ?? 'en-us'
---

<html lang={lang} class="animation-prepared">
  <head>
    <slot name="seo"> <SiteSeo /> </slot>
    <Analytics />
    <script is:inline>
      // 检测并应用系统主题
      const darkMode = window.matchMedia('(prefers-color-scheme: dark)');
      const updateTheme = e => {
        document.documentElement.classList.toggle('dark', e.matches);
      };
      updateTheme(darkMode);
      darkMode.addEventListener('change', updateTheme);
    </script>
  </head>

  <body
    class="h-100vh max-w-1200px min-w-390px mx-a"
    p="7.5 md:(y-0 x-20)"
    md="grid gap-x-6 cols-[3fr_1fr] rows-[1fr_9rem]"
  >
    <header
      class="transition-swup-header flex flex-col gap-2.5"
      m="7.5 md:(x-0 t-20 b-4)"
      md="row-1-2 col-2-3 justify-between items-start"
    >
      <SiteTitle />
      <SiteNavigation />
    </header>

    <main class="transition-swup-main overflow-y-scroll scrollbar-hide outline-none" md="row-1-3 col-1-2 py-20 ">
      <slot />
    </main>

    <footer class="transition-swup-footer py-7.5" md="row-2-3 col-2-3">
      <SiteFooter />
    </footer>

    <script>
      document.addEventListener('animationend', removeAnimation, false)
      function removeAnimation() {
        document.documentElement.classList.remove('animation-prepared')
        document.removeEventListener('animationend', removeAnimation, false)
      }
    </script>

    <style>
      /* 页面首次加载动画 */
      html.animation-prepared .transition-swup-header,
      html.animation-prepared .transition-swup-footer {
        animation: fade-in 0.18s cubic-bezier(0.16, 1, 0.3, 1);
      }

      html.animation-prepared .transition-swup-main {
        animation: fade-in 0.18s cubic-bezier(0.16, 1, 0.3, 1);
      }

      @keyframes fade-in {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }

      /* 页面过渡动画 */
      .transition-swup-main {
        transition: opacity 0.11s cubic-bezier(0.33, 0, 0.66, 0.33);
        opacity: 1;
      }

      html.is-animating .transition-swup-main {
        transition: opacity 0.18s cubic-bezier(0.16, 1, 0.3, 1);
        opacity: 0;
      }

      html.is-leaving .transition-swup-main {
        transition: opacity 0.06s cubic-bezier(0.32, 0, 0.67, 0);
        opacity: 0;
      }
    </style>
  </body>
</html>